{
  "name": "cursor-remote-extension",
  "displayName": "Cursor Remote",
  "description": "Pair with iOS and send APNs notifications from Cursor.",
  "version": "0.0.1",
  "publisher": "adetunjiadeyinka",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:cursorRemoteConnectionStatus",
    "onCommand:cursorRemote.startServer",
    "onCommand:cursorRemote.stopServer",
    "onCommand:cursorRemote.showPairingQr",
    "onCommand:cursorRemote.sendTestPush",
    "onCommand:cursorRemote.checkCdpConnection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorRemote.startServer",
        "title": "Cursor Remote: Start Server"
      },
      {
        "command": "cursorRemote.stopServer",
        "title": "Cursor Remote: Stop Server"
      },
      {
        "command": "cursorRemote.showPairingQr",
        "title": "Cursor Remote: Show Pairing QR"
      },
      {
        "command": "cursorRemote.sendTestPush",
        "title": "Cursor Remote: Send Test Push"
      },
      {
        "command": "cursorRemote.checkCdpConnection",
        "title": "Cursor Remote: Check CDP Connection"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursorRemote",
          "title": "Cursor Remote",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "cursorRemote": [
        {
          "type": "webview",
          "id": "cursorRemoteConnectionStatus",
          "name": "Connection",
          "contextualTitle": "CDP connection"
        }
      ]
    },
    "configuration": {
      "title": "Cursor Remote",
      "properties": {
        "cursorRemote.serverHost": {
          "type": "string",
          "default": "0.0.0.0",
          "description": "Host binding for the standalone service (for reference)."
        },
        "cursorRemote.serverPort": {
          "type": "number",
          "default": 31337,
          "description": "Port for the standalone service (for reference)."
        },
        "cursorRemote.serviceUrl": {
          "type": "string",
          "default": "http://127.0.0.1:31337",
          "description": "Base URL for the standalone cursor-remote service."
        },
        "cursorRemote.serviceEntryPath": {
          "type": "string",
          "default": "../server/dist/index.js",
          "description": "Path to service entry script, resolved from workspace root (or extension folder if no workspace)."
        },
        "cursorRemote.autoStartService": {
          "type": "boolean",
          "default": true,
          "description": "When true, starts the standalone service on extension activation if it is not already reachable at serviceUrl."
        },
        "cursorRemote.cdpUrl": {
          "type": "string",
          "default": "http://127.0.0.1:9222",
          "description": "Cursor CDP base URL. Launch Cursor with --remote-debugging-port=9222."
        },
        "cursorRemote.notifyOnAgentIdle": {
          "type": "boolean",
          "default": true,
          "description": "When true, polls CDP and notifies paired devices when a running agent task appears to finish (heuristic; may need tuning)."
        },
        "cursorRemote.agentIdlePollMs": {
          "type": "number",
          "default": 8000,
          "description": "How often to probe the workbench for agent busy/idle (milliseconds)."
        }
      }
    }
  },
  "scripts": {
    "compile": "npm --prefix ../shared run build && tsc -p ./",
    "watch": "tsc -w -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.13.8",
    "@types/qrcode": "^1.5.5",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@cursorremote/shared": "file:../shared",
    "qrcode": "^1.5.4"
  }
}
